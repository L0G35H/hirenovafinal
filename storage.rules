rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Admins check via firestore rules? Since storage rules can't query firestore easily without custom claims, I'll allow authenticated users to read and write, and let the backend enforce further if needed. Or use token claims. For now, authenticated is allowed.
    
    match /resumes/{userId}/{allPaths=**} {
      // Candidates can only read and write their own documents
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Give global read to authenticated users.
    match /resumes/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Simpler fallback since we might not have custom claims setup right now.
    }
  }
}
